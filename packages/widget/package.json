{
  "name": "@pyefi/widget",
  "version": "0.1.3",
  "description": "Embeddable Solana yield-trading widget by Pye Finance.",
  "keywords": [
    "solana",
    "defi",
    "yield",
    "staking",
    "widget",
    "pye"
  ],
  "author": "Pye Finance",
  "license": "MIT",
  "homepage": "https://github.com/pyefi/pye-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyefi/pye-widget.git",
    "directory": "packages/widget"
  },
  "bugs": {
    "url": "https://github.com/pyefi/pye-widget/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/pye-widget.es.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/pye-widget.es.js",
    "dist/pye-widget.es.js.map",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vite build --mode iife",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pyefi/sdk": "workspace:*",
    "buffer": "^6.0.3",
    "zustand": "^5.0.0",
    "immer": "^10.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@solana/web3.js": "^1.90.0",
    "@solana/wallet-adapter-base": "^0.9.0",
    "@solana/wallet-adapter-react": "^0.15.0",
    "@solana/wallet-adapter-wallets": "^0.19.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@solana/web3.js": "^1.90.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/wallet-adapter-base": "^0.9.0",
    "@solana/wallet-adapter-react": "^0.15.0",
    "@solana/wallet-adapter-react-ui": "^0.9.0",
    "@solana/wallet-adapter-wallets": "^0.19.0",
    "@solana/kit": "^2.0.0",
    "@cks-systems/manifest-sdk": ">=0.1.0",
    "@supabase/supabase-js": "^2.0.0"
  }
}
