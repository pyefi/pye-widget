{
  "name": "@pyefi/sdk",
  "version": "0.1.2",
  "description": "Core SDK for the Pye Finance Solana yield protocol — stores, data fetching, transaction execution.",
  "keywords": [
    "solana",
    "defi",
    "yield",
    "staking",
    "sdk",
    "pye"
  ],
  "author": "Pye Finance",
  "license": "MIT",
  "homepage": "https://github.com/pyefi/pye-widget#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyefi/pye-widget.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/pyefi/pye-widget/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "zustand": "^5.0.0",
    "immer": "^10.0.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.90.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/wallet-adapter-react": "^0.15.0",
    "@solana/kit": "^2.0.0",
    "@cks-systems/manifest-sdk": ">=0.1.0",
    "@supabase/supabase-js": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "@solana/wallet-adapter-react": { "optional": true },
    "@supabase/supabase-js": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "@solana/web3.js": "^1.90.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/wallet-adapter-react": "^0.15.0",
    "@solana/kit": "^2.0.0",
    "@cks-systems/manifest-sdk": ">=0.1.0",
    "@supabase/supabase-js": "^2.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  }
}
